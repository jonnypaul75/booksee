{
  "name": "BookSee.App",
  "short_name": "BookSee",
  "start_url": "/booksee/",
  "scope": "/booksee/",
  "display": "standalone",
  "background_color": "#000000",
  "lang": "en",
  "description": "Audiobook OTT player — shorts and long-format audio stories.",
  "theme_color": "#000000",
  "orientation": "portrait",
  "categories": [
    "entertainment",
    "books",
    "music"
  ],
  "icons": [
    {
      "src": "/booksee/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/booksee/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/booksee/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/booksee/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ]
}